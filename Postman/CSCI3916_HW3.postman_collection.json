    {
      "name": "POST /movies (save movie)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 201', function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "pm.test('Response contains movie with correct title', function () {",
              "    const response = pm.response.json();",
              "    pm.expect(response).to.have.property('movie');",
              "    pm.expect(response.movie.title).to.eql('Postman Test Movie');",
              "    pm.expect(response.movie.genre).to.eql('Action');",
              "    pm.expect(response.movie.actors).to.have.lengthOf(3);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
